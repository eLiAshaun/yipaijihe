# LLM API Configuration
# 支持 OpenAI 兼容接口（OpenAI / DeepSeek / 通义千问 / 本地 Ollama 等）
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_WEB_SEARCH_MODEL=gpt-4o-mini
LLM_WEB_SEARCH_CONTEXT_SIZE=medium
LLM_WIRE_API=responses
LLM_WEB_SEARCH=live

# AMap (高德地图) Web API Key（可选，用于服务端路线计算）
AMAP_KEY=your-amap-key-here

# Database
DB_PATH=instance/luvdazi.db

# Flask
FLASK_DEBUG=1
FLASK_PORT=5000

# MiMo ASR (抖音视频语音转文字)
MIMO_API_KEY=your-mimo-api-key-here
MIMO_API_BASE=https://token-plan-cn.xiaomimimo.com/v1

# 豆包 (Doubao / 火山方舟 Ark) - 用于联网搜索发现景点
DOUBAO_API_KEY=your-doubao-api-key-here
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-pro-260215
